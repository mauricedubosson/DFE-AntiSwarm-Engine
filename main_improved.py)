# 4. TEST DE VALIDATION (SCÉNARIO RÉEL)
# =============================================================================
if __name__ == "__main__":
    print("[INIT] Moteur Dubosson-Feynman amélioré activé.")
    engine = InterceptionEngine()

    # Test cible unique avec bruit
    pos_drone = torch.tensor([1000.0, 0.0, 100.0]) + torch.randn(3) * 2  # Bruit sensoriel
    vel_drone = torch.tensor([-50.0, 5.0, 0.0]) + torch.randn(3) * 0.5
    impact_point = engine.predict_lead_point(pos_drone, vel_drone)
    print(f"\n[CIBLE] Drone Shahed détecté à {pos_drone[0]:.1f}m")
    print(f"[CALCUL] Point d'interception (Lead) : {impact_point.tolist()}")
    print("[ACTION] Solution de tir envoyée aux servomoteurs.")

    # Test swarm
    swarm_pos = [pos_drone + torch.randn(3) * 10 for _ in range(3)]
    swarm_vel = [vel_drone + torch.randn(3) * 1 for _ in range(3)]
    swarm_intercepts = engine.handle_swarm(swarm_pos, swarm_vel)
    print("\n[SWARM] Points d'interception :", [p.tolist() for p in swarm_intercepts])

    # Test évolution symbolique (loi pour TOF approx)
    t = np.linspace(0, 5, 50)
    dist = 1000 - 50 * t
    v = np.full_like(t, 820)
    g = np.full_like(t, 9.81)
    tof_target = dist / v + (0.5 * g * (dist / v)**2) / v  # Approx avec gravité
    x_data = np.stack([dist, v, t, g])
    law = engine.explorer.evolve_law(x_data, tof_target, gens=20, pop_size=50)
    print(f"\n[LAW] Loi évoluée pour TOF : {law}")
